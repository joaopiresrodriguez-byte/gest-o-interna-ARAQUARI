VITE_GROQ_API_KEY=
VITE_GOOGLE_SEARCH_API_KEY=
VITE_SEARCH_ENGINE_ID=
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_GOOGLE_SHEETS_WEBHOOK_URL=

# ─── Google Drive / Sheets — Sincronização B1 ────────────────────────────────
# Endpoint do servidor/proxy que retorna o access_token OAuth2 da service account
VITE_GOOGLE_TOKEN_ENDPOINT=

# IDs das planilhas Google Sheets (compartilhar com a service account como Editor)
VITE_SHEETS_EFETIVO_ID=
VITE_SHEETS_ESCALA_ID=
VITE_SHEETS_FERIAS_ID=

# IDs das pastas no Google Drive (compartilhar com a service account como Editor)
VITE_DRIVE_DOCS_FOLDER_ID=
VITE_DRIVE_BOL_FOLDER_ID=

# ─── Instruções de configuração ──────────────────────────────────────────────
# 1. Crie um projeto no Google Cloud Console
# 2. Habilite: Google Sheets API e Google Drive API
# 3. Crie uma Service Account e baixe a chave JSON
# 4. Compartilhe as planilhas/pastas com o e-mail da service account (Editor)
# 5. Configure um endpoint seguro (ex: Supabase Edge Function) que:
#    - Lê as credenciais da service account de variáveis de ambiente seguras
#    - Retorna um access_token OAuth2 válido
#    - URL desse endpoint → VITE_GOOGLE_TOKEN_ENDPOINT
# 6. Conta de referência: b1araquari@gmail.com (deve ser Editor nas planilhas)
