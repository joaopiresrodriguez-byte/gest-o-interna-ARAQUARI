# ─── APIs e Integrações Externas ─────────────────────────────────────────────
VITE_GROQ_API_KEY=
VITE_GOOGLE_SEARCH_API_KEY=
VITE_SEARCH_ENGINE_ID=

# ─── Supabase ─────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ─── Google Apps Script Webhook (usado para TODAS as gravações no Sheets) ─────
# COMO OBTER: Apps Script editor → Implantar → Nova implantação → App da Web
#             Executar como: Eu | Acesso: Qualquer pessoa → Implantar → copiar URL
# FORMATO:    https://script.google.com/macros/s/SEU_ID/exec
VITE_GOOGLE_SHEETS_WEBHOOK_URL=

# ─── Google Sheets API Key (somente leitura/legacy, não usada para escrita) ───
VITE_GOOGLE_SHEETS_API_KEY=

# ─── IDs das Planilhas Google Sheets ─────────────────────────────────────────
# Planilha Mestre B1 (CadastroEfetivo, CursosEfetivo, Férias, Disciplina)
VITE_SHEETS_EFETIVO_ID=

# Planilhas opcionais (se usar abas separadas)
VITE_SHEETS_ESCALA_ID=
VITE_SHEETS_FERIAS_ID=

# ─── IDs das Pastas no Google Drive ──────────────────────────────────────────
# Pasta principal de documentos do efetivo e arquivos do sistema
VITE_DRIVE_DOCS_FOLDER_ID=

# Pasta para boletins e documentos oficiais
VITE_DRIVE_BOL_FOLDER_ID=

# ─── Endpoint de Token OAuth2 (opcional — para service account futura) ───────
VITE_GOOGLE_TOKEN_ENDPOINT=
